# =============================================================================
# EduAI Nepal — environment variables
# Copy to `.env` at repo root. Never commit `.env`.
# Local keys: run `pnpm db:status` after `pnpm db:start`
# =============================================================================

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development
# Nepal Standard Time (UTC+5:45) — school calendar / quiet-hours / "today"
TZ=Asia/Kathmandu

# --- App ports (separate so `pnpm dev` can run all services in parallel) -----
API_PORT=3000
WEB_PORT=5173
DOCGEN_PORT=3002
JOBS_PORT=3003

# --- Supabase (API URL — not the Postgres connection string) -----------------
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres (migrations, admin tools — from `pnpm db:status` Database URL)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase local storage (S3-compatible — from `pnpm db:status` Storage section)
SUPABASE_STORAGE_S3_ENDPOINT=http://127.0.0.1:54321/storage/v1/s3
SUPABASE_STORAGE_ACCESS_KEY=
SUPABASE_STORAGE_SECRET_KEY=
SUPABASE_STORAGE_REGION=local

# --- Web (Svelte SPA — PUBLIC_* / VITE_* exposed to the browser) ------------
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=
PUBLIC_API_URL=http://localhost:3000
PUBLIC_APP_NAME=EduAI Nepal
VITE_API_URL=http://localhost:3000
VITE_APP_NAME=EduAI Nepal

# Passwords live in Supabase Auth (auth.users) — never store app passwords in Postgres.
# Never expose SUPABASE_SERVICE_ROLE_KEY via VITE_* or PUBLIC_* (browser-visible) vars.

# OTP / account recovery (WhatsApp primary, SMS fallback — not web sign-in)
OTP_EXPIRES_IN_SECONDS=300
OTP_MAX_ATTEMPTS=5

# --- Messaging ---------------------------------------------------------------
# Meta WhatsApp Cloud API
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# SMS OTP fallback (Twilio Verify or MSG91 — configure one)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=

# --- AI (Anthropic) ----------------------------------------------------------
ANTHROPIC_API_KEY=
# Model IDs — override only when testing; defaults match Architecture 7
ANTHROPIC_HAIKU_MODEL=claude-3-5-haiku-latest
ANTHROPIC_SONNET_MODEL=claude-3-5-sonnet-latest

# --- Cache (Upstash Redis) ---------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_CACHE_TTL_SECONDS=2592000

# --- File storage (Cloudflare R2 — production; local uses Supabase storage) --
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# --- Background jobs (Inngest or Trigger.dev — pick one) ---------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=

# --- Internal service URLs (server-to-server) --------------------------------
DOCGEN_SERVICE_URL=http://localhost:3002
JOBS_SERVICE_URL=http://localhost:3003

# --- Observability -----------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
AXIOM_TOKEN=
AXIOM_DATASET=

# --- CORS / security (API) ---------------------------------------------------
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# --- Feature flags (dev overrides) -------------------------------------------
# LOG_LEVEL=debug
