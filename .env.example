# Copy to .env at repo root. Never commit .env.

# API (NestJS)
PORT=3000

# Supabase — run `pnpm db:status` after `pnpm db:start` for local keys
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Web (SvelteKit) — public vars exposed to the browser
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=
PUBLIC_API_URL=http://localhost:3000

# Docgen
# PORT=3002

# Jobs
# PORT=3003
