{
  "name": "@eduai/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "generate:api-types": "openapi-typescript ${VITE_API_URL:-http://localhost:3000}/api/docs-json -o src/lib/shared/api/generated-types.ts"
  },
  "dependencies": {
    "@keenmate/svelte-spa-router": "^5.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@tailwindcss/vite": "^4.1.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@testing-library/user-event": "^14.6.1",
    "eslint": "^9.39.5",
    "happy-dom": "^20.10.6",
    "openapi-typescript": "^7.13.0",
    "svelte": "^5.33.14",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
